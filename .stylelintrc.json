{
  "extends": [
    "stylelint-config-standard-scss"
  ],
  "plugins": [
    "stylelint-order"
  ],
  "rules": {
    "selector-class-pattern": null,
    "no-descending-specificity": null,
    "scss/at-extend-no-missing-placeholder": null,
    "order/properties-alphabetical-order": null,
    "order/order": [
      "custom-properties",
      "declarations"
    ]
  }
}
